{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user in the Kyzzy Protocol Matrix.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "recoveryKey": { "type": "string" },
        "role": { 
          "type": "string",
          "enum": ["OWNER", "ADMIN", "RESELLER", "MEMBER"]
        },
        "tier": {
          "type": "string",
          "enum": ["Lifetime", "Premium", "Free"]
        },
        "expiry": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "role", "tier"]
    },
    "PremiumKey": {
      "title": "Premium Key",
      "description": "Access serial key for upgrading clearance.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "durationDays": { "type": "number" },
        "targetRole": { 
          "type": "string",
          "enum": ["ADMIN", "RESELLER", "MEMBER"]
        },
        "status": {
          "type": "string",
          "enum": ["unused", "used"]
        },
        "usedBy": { "type": "string" },
        "targetUser": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "durationDays", "targetRole", "status"]
    }
  },
  "firestore": {
    "users/{username}": {
      "schema": "UserProfile",
      "description": "Individual user records mapped by lowercase username."
    },
    "premiumKeys/{keyId}": {
      "schema": "PremiumKey",
      "description": "Matrix access keys."
    }
  }
}
