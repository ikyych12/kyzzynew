rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Master Admin bypass using your verified email
    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == "kytyg800@gmail.com";
    }

    // Check if current authenticated user is an admin or owner
    function isAdminOrOwner() {
      return isMasterAdmin();
      // Note: We avoid checking users/{uid} because document IDs are currently usernames
    }
    
    // --- Users Collection ---
    match /users/{username} {
      function isValidUser(data) {
        return data.username is string && data.username.size() <= 64 &&
               data.role in ['OWNER', 'ADMIN', 'RESELLER', 'MEMBER'] &&
               data.tier in ['Lifetime', 'Premium', 'Free'] &&
               (data.get('password', '') is string) &&
               (data.get('recoveryKey', '') is string) &&
               (data.get('isBanned', false) is bool) &&
               (data.get('bannedReason', '') is string) &&
               data.keys().hasAll(['username', 'role', 'tier']);
      }

      // Allow public get for identity verification during login
      allow get: if true;

      // Allow listing users for admin panel or recovery key lookup
      allow list: if isSignedIn();

      allow create: if (
        isMasterAdmin() || (
          isValidId(username) && 
          isValidUser(incoming()) &&
          incoming().role == 'MEMBER' && 
          incoming().tier == 'Free'
        )
      );
      
      allow update: if (
        isMasterAdmin() || (
          isSignedIn() && (
            (request.auth.uid == username && incoming().diff(existing()).affectedKeys().hasOnly(['password', 'recoveryKey']))
          ) && isValidUser(incoming())
        )
      );
      
      allow delete: if isMasterAdmin() && username != 'iky' && username != 'kyzzy';
    }

    // --- Recovery Keys Mapping ---
    match /recoveryKeys/{token} {
      allow get: if true;
      allow create: if isSignedIn();
      allow delete: if isMasterAdmin();
    }

    // --- Premium Keys ---
    match /premiumKeys/{keyId} {
      function isValidKey(data) {
        return data.key is string && data.key.size() <= 128 &&
               data.durationDays is number &&
               data.targetRole in ['ADMIN', 'RESELLER', 'MEMBER'] &&
               data.status in ['unused', 'used'] &&
               data.keys().hasAll(['key', 'durationDays', 'targetRole', 'status']);
      }

      // Allow public get to validate a key before login
      allow get: if true;
      
      // List and other ops require auth
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && (isMasterAdmin() || isAdminOrOwner()) && isValidKey(incoming());
      
      allow update: if isSignedIn() && (
        isMasterAdmin() ||
        isAdminOrOwner() ||
        (existing().status == 'unused' && incoming().status == 'used' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'usedBy']))
      ) && isValidKey(incoming());
      
      allow delete: if isSignedIn() && (isMasterAdmin() || isAdminOrOwner());
    }
  }
}
